# GitHub Authentication
# Not required when using HTTP-based GitHub MCP server
# Authentication is handled through GitHub Copilot session
# GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Azure Authentication (Optional - can be provided interactively)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# AKS Cluster Information (Optional - can be provided interactively)
# AKS_CLUSTER_NAME=your-cluster-name
# AKS_RESOURCE_GROUP=your-resource-group
