{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "EVENT_TYPE=SessionStart bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "EVENT_TYPE=UserPromptSubmit bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "EVENT_TYPE=PreToolUse bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "EVENT_TYPE=PostToolUse bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "EVENT_TYPE=PreCompact bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "EVENT_TYPE=SubagentStart bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "EVENT_TYPE=SubagentStop bash .github/hooks/scripts/session-logger.sh",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "EVENT_TYPE=Stop bash .github/hooks/scripts/session-logger.sh",
        "timeout": 15
      }
    ]
  }
}